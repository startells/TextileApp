<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <!-- DataGrid Style -->
    <Style x:Key="TableDataGridStyle" TargetType="controls:DataGrid">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="RowDetailsVisibilityMode" Value="VisibleWhenSelected"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="CanUserReorderColumns" Value="False"/>
        <Setter Property="CanUserResizeColumns" Value="True"/>
        <Setter Property="CanUserSortColumns" Value="True"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeight" Value="40"/>
    </Style>

    <!-- Table Header Style -->
    <Style x:Key="TableHeaderGridStyle" TargetType="Grid">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="CornerRadius" Value="8,8,0,0"/>
    </Style>

    <!-- Table Header TextBlock Style -->
    <Style x:Key="TableHeaderTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Table Row Style -->
    <Style x:Key="TableRowGridStyle" TargetType="Grid">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <!-- Table Cell TextBlock Style -->
    <Style x:Key="TableCellTextBlockStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Table Container Style -->
    <Style x:Key="TableContainerGridStyle" TargetType="Grid">
        <Setter Property="RowSpacing" Value="0"/>
    </Style>

    <!-- Standard Column Widths as Resources -->
    <x:Double x:Key="TableColumnSmall">60</x:Double>
    <x:Double x:Key="TableColumnMedium">100</x:Double>
    <x:Double x:Key="TableColumnLarge">150</x:Double>
    <x:Double x:Key="TableColumnXLarge">200</x:Double>

    <!-- Material Table Column Widths -->
    <GridLength x:Key="MaterialIdColumnWidth">60</GridLength>
    <GridLength x:Key="MaterialNameColumnWidth">180</GridLength>
    <GridLength x:Key="MaterialCompositionColumnWidth">150</GridLength>
    <GridLength x:Key="MaterialWidthColumnWidth">80</GridLength>
    <GridLength x:Key="MaterialPriceColumnWidth">100</GridLength>
    <GridLength x:Key="MaterialColorColumnWidth">100</GridLength>
    <GridLength x:Key="MaterialStockColumnWidth">100</GridLength>
    <GridLength x:Key="MaterialSupplierColumnWidth">120</GridLength>
    <GridLength x:Key="MaterialDateColumnWidth">120</GridLength>

</ResourceDictionary>
