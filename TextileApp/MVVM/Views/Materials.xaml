<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TextileApp.MVVM.Views.Materials"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TextileApp.MVVM.Views"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="{Binding ViewModel.Title}" 
                   FontSize="32" 
                   FontWeight="Bold"
                   Foreground="{ThemeResource TextFillColorPrimary}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
            <Button Command="{Binding ViewModel.AddMaterialCommand}" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Add"/>
                    <TextBlock Text="Добавить"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ViewModel.EditMaterialCommand}" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Edit"/>
                    <TextBlock Text="Редактировать"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding ViewModel.DeleteMaterialCommand}" Padding="16,8" Background="#FFCC0000" Foreground="White">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Delete"/>
                    <TextBlock Text="Удалить"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Materials DataGrid -->
        <controls:DataGrid Grid.Row="2" 
                          ItemsSource="{Binding ViewModel.Materials}"
                          SelectedItem="{Binding ViewModel.SelectedMaterial, Mode=TwoWay}"
                          Style="{StaticResource TableDataGridStyle}"
                          AutoGenerateColumns="False">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="ID" Binding="{Binding MaterialId}" Width="60"/>
                <controls:DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="180"/>
                <controls:DataGridTextColumn Header="Состав" Binding="{Binding Composition}" Width="150"/>
                <controls:DataGridTextColumn Header="Ширина" Binding="{Binding Width}" Width="80"/>
                <controls:DataGridTextColumn Header="Цена за м." Binding="{Binding PricePerMeter}" Width="100"/>
                <controls:DataGridTextColumn Header="Цвет" Binding="{Binding Color}" Width="100"/>
                <controls:DataGridTextColumn Header="Количество" Binding="{Binding StockQuantity}" Width="100"/>
                <controls:DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier}" Width="120"/>
                <controls:DataGridTextColumn Header="Дата прибытия" Binding="{Binding ArrivalDate}" Width="120"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

    </Grid>
</Page>
