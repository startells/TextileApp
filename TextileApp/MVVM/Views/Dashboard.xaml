<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TextileApp.MVVM.Views.Dashboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TextileApp.MVVM.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding ViewModel.Title}" 
                   FontSize="32" 
                   FontWeight="Bold"
                   Foreground="{ThemeResource TextFillColorPrimary}"/>

        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Материалы -->
            <Grid Padding="20" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Материалы" FontSize="16" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <TextBlock Grid.Row="1" Text="{Binding ViewModel.MaterialsCount}" FontSize="48" FontWeight="Bold" Margin="0,8,0,8"/>
                <Button Grid.Row="2" Command="{Binding ViewModel.LoadDataCommand}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh"/>
                        <TextBlock Text="Обновить"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Активные заказы -->
            <Grid Grid.Column="1" Padding="20" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Активные заказы" FontSize="16" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <TextBlock Grid.Row="1" Text="{Binding ViewModel.ActiveOrdersCount}" FontSize="48" FontWeight="Bold" Margin="0,8,0,8"/>
                <Button Grid.Row="2" Command="{Binding ViewModel.LoadDataCommand}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh"/>
                        <TextBlock Text="Обновить"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Клиенты -->
            <Grid Grid.Column="2" Padding="20" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Клиенты" FontSize="16" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <TextBlock Grid.Row="1" Text="{Binding ViewModel.ClientsCount}" FontSize="48" FontWeight="Bold" Margin="0,8,0,8"/>
                <Button Grid.Row="2" Command="{Binding ViewModel.LoadDataCommand}" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh"/>
                        <TextBlock Text="Обновить"/>
                    </StackPanel>
                </Button>
            </Grid>

        </Grid>

    </Grid>
</Page>
